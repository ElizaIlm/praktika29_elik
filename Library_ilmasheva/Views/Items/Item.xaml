<UserControl x:Class="Library_ilmasheva.Views.Items.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Library_ilmasheva.Views.Items"
            mc:Ignorable="d"
            HorizontalAlignment="Stretch" Margin="5"
              FontFamily="Bahnschrift Light Condensed">
    <UserControl.Resources>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#ff2dd61b"/>
            <Setter Property="BorderBrush" Value="#ff2dd61b"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="Delete">
            <Setter Property="Background" Value="#ffd62f1b"/>
            <Setter Property="BorderBrush" Value="#ffd62f1b"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10" Background="White">
        <Grid.Effect>
            <DropShadowEffect Opacity="0.1"/>
        </Grid.Effect>
        <Image Width="60" Height="53" Margin="6,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Source="/Images/ic-book.jpg"/>

        <Grid Margin="60,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <Grid Margin="10" Height="60" VerticalAlignment="Top" Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Название:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <TextBox Text="{Binding Title}" IsEnabled="{Binding IsEnable}" VerticalContentAlignment="Center" Margin="10,25,10,0" VerticalAlignment="Top" Height="25"/>
            </Grid>
            <Grid Margin="10,80,10,0" Height="60" VerticalAlignment="Top" Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Автор:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <TextBox Text="{Binding Author}" IsEnabled="{Binding IsEnable}" VerticalContentAlignment="Center" Margin="10,25,10,0" VerticalAlignment="Top" Height="25"/>
            </Grid>
            <Grid Margin="10,10,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.Column="1">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Год издания:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <TextBox Text="{Binding YearPublish}" IsEnabled="{Binding IsEnable}" VerticalContentAlignment="Center" Margin="10,25,10,0" VerticalAlignment="Top" Height="25"/>
            </Grid>
            <Grid Margin="10,80,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.Column="1">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Жанр:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <TextBox Text="{Binding Genre}" IsEnabled="{Binding IsEnable}" VerticalContentAlignment="Center" Margin="10,25,10,0" VerticalAlignment="Top" Height="25"/>
            </Grid>
            <Button Style="{StaticResource Update}" Command="{Binding OnEdit}" Content="{Binding IsEnableText}" Height="25" Width="70" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,145,10,0" Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>

            <Button Style="{StaticResource Update}" IsEnabled="{Binding IsEnable}" Command="{Binding OnRead}" Content="{Binding IsReadText}" Height="25" Width="70" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,145,85,10" Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>

            <Button Style="{StaticResource Delete}" Command="{Binding OnDelete}" IsEnabled="{Binding IsEnable}" Content="Удалить" Height="25" Width="70" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,145,160,0" Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>
        </Grid>
    </Grid>
</UserControl>
